rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Channels and videos - authenticated read only, write for admin SDK
    match /channels/{channelId} {
      allow read: if isAuthenticated();
      allow write: if false;  // Only admin SDK can write

      match /videos/{videoId} {
        allow read: if isAuthenticated();
        allow write: if false;

        match /analysis/{analysisType} {
          allow read: if isAuthenticated();
          allow write: if false;
        }
      }
    }

    // Insights - authenticated read only for clients
    // Note: Firebase Functions using Admin SDK bypass these rules
    match /insights/{insightType} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Progress tracking - admin only (no client access)
    match /scrape_progress/{channelId} {
      allow read, write: if false;
    }

    match /analysis_progress/{progressId} {
      allow read, write: if false;
    }
  }
}
